{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Example",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "cmd/example/main.go",
			// On Windows, we attach to a binary we build ourselves rather than letting dlv rebuild & relaunch the
			// program. The dlv-built/launched binary renders a blank window on Windows; a normally-built one does not.
			"windows": {
				"mode": "exec",
				"preLaunchTask": "build example",
				"program": "${workspaceFolder}/example.exe"
			}
		}
	]
}
